payer:
  account_id: "123456789012"   # Payer (management) account ID. Profile is resolved automatically.

analysis:
  services:
    - rds
    # - elasticache
    # - opensearch
    # - redshift

  sections:
    - expiration
    - coverage
    - utilization

  regions:
    - ap-northeast-1
    # - us-east-1

  # Cost Explorer lookback period (days)
  # end   = UTC now - 48h (CE data lag)
  # start = end - lookback_days
  # Note: values below 7 may cause CE to return incomplete results
  lookback_days: 7

  # RI expiration warning threshold (days)
  expiration_warn_days: 90
