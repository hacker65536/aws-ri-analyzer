payer:
  account_id: "123456789012"   # Payer (management) account ID.
  # profile: "my-payer-profile"  # Optional. If omitted, resolved automatically from ~/.aws/config
                                  # using the account_id (AWS SSO / IAM Identity Center naming convention).
                                  # Specify explicitly when using access keys, AssumeRole, or non-SSO profiles.

analysis:
  services:
    - rds
    # - elasticache
    # - opensearch
    # - redshift

  sections:
    - expiration
    - coverage
    - utilization

  regions:
    - ap-northeast-1
    # - us-east-1

  # Cost Explorer lookback period (days)
  # end   = UTC now - 48h (CE data lag)
  # start = end - lookback_days
  # Note: values below 7 may cause CE to return incomplete results
  lookback_days: 7

  # RI expiration warning threshold (days)
  expiration_warn_days: 90

  # Cache TTL in hours for AWS API responses (default: 24).
  # Use --no-cache flag to bypass cache and force fresh data.
  cache_ttl_hours: 24
